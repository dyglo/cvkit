{
  "name": "cvkit",
  "version": "0.1.0",
  "description": "Computer Vision Toolkit — CLI for CV engineers",
  "type": "module",
  "bin": {
    "cvkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "postbuild": "node -e \"import('node:fs').then((fs)=>fs.chmodSync('dist/index.js',0o755))\"",
    "fixtures": "tsx scripts/gen-fixtures.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run fixtures && npm run build && node --import tsx --test test/cli.test.ts"
  },
  "keywords": [
    "computer-vision",
    "cli",
    "cv",
    "yolo",
    "dataset",
    "machine-learning"
  ],
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ink": "6.8.0",
    "openai": "6.29.0",
    "pg": "8.20.0",
    "react": "19.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
